{
  "expo": {
    "name": "DSDMini",
    "slug": "DSDMini",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.DSDMini",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Для отслеживания маршрута доставки",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Для фонового отслеживания маршрута доставки",
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.anonymous.DSDMini",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "yandexMapApiKey": "b86f674c-5cc1-470b-aadf-9ae9091faee9"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      "./src/plugins/withYandexMaps",
      "expo-sharing",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Приложению нужен доступ к геолокации для отслеживания маршрута доставки."
        }
      ],
      "expo-task-manager"
    ]
  }
}
