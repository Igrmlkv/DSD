{
  "expo": {
    "name": "DSDMini",
    "slug": "DSDMini",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.DSDMini",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Для отслеживания маршрута доставки",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Для фонового отслеживания маршрута доставки",
        "UIBackgroundModes": [
          "location",
          "location"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true,
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.anonymous.DSDMini",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "415bfed9-72d3-45ef-a28a-72cdcec166a7"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      "./src/plugins/withYandexMaps",
      "expo-sharing",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Приложению нужен доступ к геолокации для отслеживания маршрута доставки."
        }
      ],
      "expo-task-manager",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Для сканирования QR-кодов необходим доступ к камере",
          "barcodeScannerEnabled": true
        }
      ]
    ]
  }
}
